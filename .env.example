# Hugging Face token (optional)
# Increases rate limits: 100 → 1000 req/hour
# Get it at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Semantic Scholar API key (optional)
# Increases rate limits: 100 req/5min → 1 req/sec
# Get it at: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# Output directory for scraped JSON files (optional, default: ./data)
EARLYBIRD_DATA_DIR=./data
